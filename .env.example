# ============================================================================
# API HTTP (api/)
# ============================================================================
FLOWBRIDGE_API_KEY=tandercatxauxau
FLOWBRIDGE_PUBLIC_URL=https://flowbridge.seudominio.com
# 3000, 3333, 8081, 80 e 443 já estão em uso no servidor (evolution_frontend, api-api,
# evolution_adminer, caddy) — 3001 é a próxima livre.
PORT=3001

# ============================================================================
# Postgres (Supabase ou qualquer outro Postgres gerenciado) — persistência das instâncias
# (obrigatório; a API não sobe sem isso). Pegue em Project Settings → Database →
# Connection string no seu projeto Supabase. Sem serviço local de banco — fica hospedado lá.
# ============================================================================
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.SEUPROJETO.supabase.co:5432/postgres
# DATABASE_SSL=false   # só se estiver usando um Postgres local sem TLS (Supabase sempre exige TLS)

# ============================================================================
# Evolution API — opcional, só se for usar esse provider
# ============================================================================
# EVOLUTION_API_URL=https://evolution.seudominio.com
# EVOLUTION_API_KEY=
# EVOLUTION_THROW_ON_ERROR=false
# EVOLUTION_TIMEOUT_MS=15000

# ============================================================================
# Z-API e Meta Cloud API não têm env vars globais — cada instância é criada com suas
# próprias credenciais via POST /v1/instances (ver README, seção "API HTTP").
# WHATSAPP_CLOUD_APP_SECRET pode ser definido por instância nas credentials, se preferir
# fixar globalmente aqui não é suportado nesta versão.
# ============================================================================
